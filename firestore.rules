rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin
    // Note: This requires the user document to exist in the users collection
    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Products collection - anyone can read; admins can do everything; authenticated users can update only rating fields
    match /products/{productId} {
      allow read: if true; // Anyone can read products
      allow create, delete: if isAdmin(); // Only admins can create/delete products
      allow update: if isAdmin()
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'rating', 'reviewCount', 'updatedAt'
            ]));
    }

    // Reviews collection - for post-checkout ratings
    match /reviews/{reviewId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['productId', 'userId', 'orderId', 'rating', 'createdAt']);
      allow read: if true;
      allow update, delete: if false;
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      // Anyone can create an appointment (even without auth for guest bookings)
      allow create: if true;

      // Users can read their own appointments
      allow read: if isAuthenticated() &&
                     (isOwner(resource.data.userId) || isAdmin());

      // Only admins can update or delete appointments
      allow update, delete: if isAdmin();
    }

    // Orders collection - guests can create (checkout without login); users read own, admins read all
    match /orders/{orderId} {
      allow create: if true; // Guest checkout allowed

      // Users can read their own orders (when userId matches), admins can read all
      allow read: if isAuthenticated() &&
                     (isOwner(resource.data.userId) || isAdmin());

      // Only admins can update or delete orders
      allow update, delete: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own data, admins can read all
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());

      // Users can create their own document on signup, admins can create/update any
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());

      // Only admins can update user documents (for role changes)
      allow update: if isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    match /settings/currencyRates {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Stores collection (store locations) - anyone can read; only admins can write
    match /stores/{storeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
